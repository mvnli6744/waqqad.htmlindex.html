rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isAdminOrOwner() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    function isOwner() {
      return isAdminOrOwner() &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.isOwner == true;
    }
    function isLocked() {
      return exists(/databases/$(database)/documents/config/lockdown) &&
        get(/databases/$(database)/documents/config/lockdown).data.locked == true;
    }
    // A driver name with no driverAssignments doc is unrestricted (backward
    // compatible with every driver that predates this feature). One with a doc
    // may only log the plates listed in it.
    function isAssignedPlate(driverName, plate) {
      return !exists(/databases/$(database)/documents/driverAssignments/$(driverName)) ||
        plate in get(/databases/$(database)/documents/driverAssignments/$(driverName)).data.plates;
    }

    // Admin/owner roster, keyed by Firebase Auth uid. Only an existing owner may
    // add/remove/edit entries here.
    match /admins/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner()
        && request.resource.data.keys().hasOnly(['name','email','isOwner','createdAt','pages'])
        && request.resource.data.name is string && request.resource.data.name.size() > 0 && request.resource.data.name.size() < 100
        && request.resource.data.email is string
        && request.resource.data.isOwner is bool
        && request.resource.data.createdAt == request.time;
      allow update: if isOwner()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name','isOwner','pages'])
        && (!('pages' in request.resource.data) || (request.resource.data.pages is list && request.resource.data.pages.size() < 20));
      allow delete: if isOwner() && request.auth.uid != uid;
    }

    // Fuel log entries. Drivers are anonymous-auth clients: they may append a
    // well-formed entry but can NEVER list/query the collection (that would leak
    // company-wide fuel/deviation data to every driver, and pull the whole fleet
    // history over their mobile connection). Only admin/owner can list + review.
    match /logs/{id} {
      allow get: if isSignedIn();
      allow list: if isAdminOrOwner();
      allow create: if isSignedIn() && (isAdminOrOwner() || (!isLocked() && isAssignedPlate(request.resource.data.driverName, request.resource.data.plate)))
        && request.resource.data.keys().hasOnly(['plate','date','time','prev','curr','liters','station','notes','driverName','ar','dev','st','sl','ref','un','reviewed','createdAt','photoPrev','photoCurr','spot'])
        && request.resource.data.plate is string && request.resource.data.plate.size() > 0 && request.resource.data.plate.size() < 40
        && request.resource.data.driverName is string && request.resource.data.driverName.size() > 0 && request.resource.data.driverName.size() < 100
        && request.resource.data.prev is number && request.resource.data.curr is number
        && request.resource.data.curr > request.resource.data.prev
        // 1000L is a blunt fleet-wide backstop (the real per-vehicle tank-size
        // check lives client-side, keyed by usage type); this just guarantees
        // no write — tampered client or not — can claim an absurd fill-up.
        && request.resource.data.liters is number && request.resource.data.liters > 0 && request.resource.data.liters < 1000
        && (!('photoPrev' in request.resource.data) || (request.resource.data.photoPrev is string && request.resource.data.photoPrev.size() < 350000))
        && (!('photoCurr' in request.resource.data) || (request.resource.data.photoCurr is string && request.resource.data.photoCurr.size() < 350000))
        && request.resource.data.reviewed == false
        && request.resource.data.createdAt == request.time;
      // Segregation of duties: a "red" (critical waste) entry can only be
      // dismissed/approved by the owner — a regular admin (who might be the
      // one covering for a driver) can only review yellow/orange/spot-checked.
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reviewed'])
        && (isOwner() || (isAdminOrOwner() && resource.data.st != 'red'));
      allow delete: if isOwner();
    }

    // Denormalized "latest reading" per vehicle — lets drivers see/prefill the
    // previous odometer/hour reading without needing any access to full log history.
    match /vehicles/{plate} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && request.resource.data.keys().hasOnly(['lastCurr','lastDate','lastTime','lastDriverName'])
        && request.resource.data.lastCurr is number
        && request.resource.data.lastDate is string && request.resource.data.lastDate.size() < 20
        && request.resource.data.lastTime is string && request.resource.data.lastTime.size() < 10
        && request.resource.data.lastDriverName is string && request.resource.data.lastDriverName.size() < 100;
    }

    // Fleet directory delta (additions/removals on top of the built-in vehicle list).
    match /fleetOv/current {
      allow read: if isSignedIn();
      allow write: if isOwner();
    }

    // Owner-managed driver roster (names drivers pick from at sign-in).
    match /drivers/current {
      allow read: if isSignedIn();
      allow write: if isOwner()
        && request.resource.data.keys().hasOnly(['list'])
        && request.resource.data.list is list
        && request.resource.data.list.size() < 2000;
    }

    // Owner-managed approved fuel-station list (drivers pick from it instead
    // of free text, to cut down on claims of purchases from unlisted stations).
    match /stations/current {
      allow read: if isSignedIn();
      allow write: if isOwner()
        && request.resource.data.keys().hasOnly(['list'])
        && request.resource.data.list is list
        && request.resource.data.list.size() < 500;
    }

    // Owner-calibrated reference consumption rates (overrides on top of the
    // built-in table baked into the app).
    match /refRates/current {
      allow read: if isSignedIn();
      allow write: if isOwner()
        && request.resource.data.keys().hasOnly(['overrides'])
        && request.resource.data.overrides is map;
    }

    // Maintenance / fault log, tied to a plate. Any admin/owner can add one;
    // only the owner can delete.
    match /maintenance/{id} {
      allow read: if isAdminOrOwner();
      allow create: if isAdminOrOwner()
        && request.resource.data.keys().hasOnly(['plate','type','date','desc','cost','createdAt'])
        && request.resource.data.plate is string && request.resource.data.plate.size() > 0 && request.resource.data.plate.size() < 40
        && request.resource.data.type is string && request.resource.data.type.size() < 40
        && request.resource.data.date is string && request.resource.data.date.size() < 20
        && request.resource.data.createdAt == request.time;
      allow delete: if isOwner();
    }

    // Emergency lockdown switch. Any signed-in client needs to read it (drivers'
    // clients check it before allowing a login attempt), only the owner can flip it.
    match /config/lockdown {
      allow read: if isSignedIn();
      allow write: if isOwner()
        && request.resource.data.keys().hasOnly(['locked','by','at'])
        && request.resource.data.locked is bool
        && request.resource.data.by is string
        && request.resource.data.at == request.time;
    }

    // Per-device heartbeat written on every driver login — lets a driver's own
    // client compare against its last-known device (get, by exact name) to
    // flag possible credential sharing, while only admin/owner can query
    // ("list") the collection to see who else is currently active.
    match /driverSessions/{name} {
      allow get: if isSignedIn();
      allow list: if isAdminOrOwner();
      allow write: if isSignedIn()
        && request.resource.data.keys().hasOnly(['deviceId','driverName','alert','at'])
        && request.resource.data.deviceId is string && request.resource.data.deviceId.size() > 0 && request.resource.data.deviceId.size() < 100
        && request.resource.data.driverName is string
        && request.resource.data.alert is bool
        && request.resource.data.at == request.time;
    }

    // Owner-set restriction on which plates a driver name may log fuel for.
    // Readable by any signed-in client so a driver's own client can filter its
    // plate search to only what it's allowed to submit (server-side enforcement
    // is the isAssignedPlate() check on logs/{id} create, this is just UX).
    match /driverAssignments/{name} {
      allow read: if isSignedIn();
      allow write: if isOwner()
        && request.resource.data.keys().hasOnly(['plates'])
        && request.resource.data.plates is list
        && request.resource.data.plates.size() > 0 && request.resource.data.plates.size() < 500;
    }

    // Lightweight flag a driver's own client can check ("has an Iqama photo
    // already been captured under this name?") without ever reading the photo
    // itself — the mandatory-on-first-login capture flow depends on this being
    // readable by any signed-in driver, unlike driverIds below.
    match /driverIdFlags/{name} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly(['done'])
        && request.resource.data.done == true;
      allow delete: if isOwner();
    }

    // The actual Iqama photo + 4-digit login PIN, base64/plain directly in the
    // doc (no Storage / Blaze plan needed). Only admin/owner can read it back;
    // captured once per driver name — the owner can delete to force a
    // re-capture (e.g. a renewed Iqama or a forgotten PIN).
    //
    // PIN verification never lets a driver's client read the real pin: the
    // client "guesses" by writing that guess into the pinCheck scratch field,
    // and the update below only succeeds if the guess equals the stored pin —
    // a permission-denied error on that write IS the "wrong PIN" signal.
    match /driverIds/{name} {
      allow read: if isAdminOrOwner();
      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly(['name','photo','pin','capturedAt'])
        && request.resource.data.name is string && request.resource.data.name.size() > 0 && request.resource.data.name.size() < 100
        && request.resource.data.photo is string && request.resource.data.photo.size() > 0 && request.resource.data.photo.size() < 900000
        && request.resource.data.pin is string && request.resource.data.pin.matches('^[0-9]{4}$')
        && request.resource.data.capturedAt == request.time;
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pinCheck'])
        && request.resource.data.pinCheck == resource.data.pin;
      allow delete: if isOwner();
    }

    // Append-only trail of privileged actions (who changed/deleted/edited what,
    // and when). Any admin/owner may append an entry when they perform an
    // action; only the owner can read the trail back. No update/delete —
    // immutable by design.
    match /auditLog/{id} {
      allow read: if isOwner();
      allow create: if isAdminOrOwner()
        && request.resource.data.keys().hasOnly(['actor','action','target','createdAt'])
        && request.resource.data.actor is string && request.resource.data.actor.size() > 0 && request.resource.data.actor.size() < 200
        && request.resource.data.action is string && request.resource.data.action.size() > 0 && request.resource.data.action.size() < 200
        && request.resource.data.target is string && request.resource.data.target.size() < 500
        && request.resource.data.createdAt == request.time;
    }
  }
}
